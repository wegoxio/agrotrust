    "OurPlatform":  {
                        "eyebrow":  "Our Platform",
                        "title":  "One Ecosystem",
                        "description":  "AgroTrust brings together the key participants in global commodity trade into one structured ecosystem. Through a controlled framework, buyers, producers, capital partners, and service providers can operate with more transparency, security, and efficiency across every stage of the transaction.",
                        "steps":  {
                                      "1":  {
                                                "title":  "Buyer due diligence \u0026 structuring",
                                                "description":  "AgroTrust begins by validating parties involved and defining the structure of the transaction. This includes assessing counterparties, aligning deal terms, and creating a framework that reduces uncertainty before execution begins."
                                            },
                                      "2":  {
                                                "title":  "Collateral \u0026 financing",
                                                "description":  "Once the deal is structured, the platform supports the financial layer of the transaction through collateral organization and funding coordination. This helps ensure that capital is deployed within a secure framework that protects all parties involved."
                                            },
                                      "3":  {
                                                "title":  "Shipment \u0026 escrow",
                                                "description":  "AgroTrust helps coordinate the operational and financial controls tied to execution, including shipment oversight and escrow mechanisms. This adds a layer of protection and transparency as goods and payments move through the process."
                                            },
                                      "4":  {
                                                "title":  "Distribution \u0026 final execution",
                                                "description":  "The final stage focuses on completing the transaction efficiently and ensuring all participants remain aligned through delivery and distribution. The result is a more seamless execution process with clearer accountability from start to finish."
                                            }
                                  },
                        "imageAlt":  "Business team hands joined together"
                    },
